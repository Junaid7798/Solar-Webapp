# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_SHEETS_URL: URL of the Google Apps Script Web App
# Used to store and retrieve leads from a Google Sheet
VITE_GOOGLE_SHEETS_URL=your_google_apps_script_url_here

# VITE_ADMIN_PASSWORD: Password for the admin dashboard
# Set a strong password — this is visible in the browser bundle, so treat it as a light gate
VITE_ADMIN_PASSWORD=your_secure_password_here

# Business info (used in PDF generation, WhatsApp messages, and sidebar)
VITE_BUSINESS_NAME=Your Solar Company
VITE_BUSINESS_PHONE=91XXXXXXXXXX
VITE_BUSINESS_EMAIL=your@email.com
VITE_BUSINESS_TAGLINE=Maharashtra Solar Specialists

# Supabase (optional — enables real backend instead of localStorage)
# Get these from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
