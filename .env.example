# VITE_ADMIN_PASSWORD: Password for the admin dashboard.
# IMPORTANT: This value is injected into the client-side JavaScript bundle by Vite.
# It serves as a light gate, NOT a secure authentication mechanism.
# Do NOT reuse passwords from other services.
# Configure this in your Vercel dashboard (Settings > Environment Variables).
VITE_ADMIN_PASSWORD=your_secure_password_here

# VITE_GOOGLE_SHEETS_URL: URL of the Google Apps Script Web App endpoint.
# Used to submit lead form data to a Google Sheet.
# IMPORTANT: This URL is visible in the client bundle. Review your Apps Script
# deployment permissions to restrict unauthorized access.
# Configure this in your Vercel dashboard (Settings > Environment Variables).
VITE_GOOGLE_SHEETS_URL=your_google_apps_script_url_here

# VITE_BUSINESS_NAME: Display name for the business.
VITE_BUSINESS_NAME=Asrar Solar

# VITE_BUSINESS_TAGLINE: Short tagline shown on the site.
VITE_BUSINESS_TAGLINE=Clean rooftop solar for homes, farms, and businesses

# VITE_BUSINESS_PHONE: Contact phone number (with country code, digits only).
VITE_BUSINESS_PHONE=918237655610

# VITE_BUSINESS_EMAIL: Contact email address.
VITE_BUSINESS_EMAIL=Junaidk5610@gmail.com
